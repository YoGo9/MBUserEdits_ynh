#!/bin/bash
source _common.sh
source /usr/share/yunohost/helpers

ynh_print_info "Stopping service..."
ynh_systemctl --service="$app" --action="stop"

ynh_print_info "Removing nginx configuration..."
ynh_config_remove_nginx

ynh_print_info "Removing systemd service..."
ynh_config_remove_systemd

# install_dir, data_dir, system user, db — all cleaned up by YunoHost resource system

ynh_print_info "MBUserEdits removed."
